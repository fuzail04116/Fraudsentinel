# ============================================
# FraudSentinel — Environment Variables
# ============================================
# Copy this file to .env and fill in real values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=fraud-transactions

# Airflow
AIRFLOW_CONN_POSTGRES_DEFAULT=postgresql://airflow:airflow@postgres/airflow
AIRFLOW_FERNET_KEY=your-fernet-key
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# Postgres
POSTGRES_USER=fraudsentinel
POSTGRES_PASSWORD=fraudsentinel_secret
POSTGRES_DB=fraudsentinel

# Slack (for Airflow notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# GitHub Actions (for deploy trigger from Airflow)
GITHUB_TOKEN=your-github-token
GITHUB_REPO=your-username/fraudsentinel

# Render (for CD)
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/your-hook
